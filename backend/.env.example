# ShotPocket backend 환경변수 예시 — 복사해서 .env 로 사용
# 계정/로그인 없음: 사용자 인증 관련 키 없음. 운영 접근은 OPS_API_KEY 만.

# 런타임
DEBUG=false

# 데이터베이스 (PostgreSQL 15 + pgvector)
DATABASE_URL=postgresql+psycopg2://shotpocket:shotpocket@db:5432/shotpocket

# Redis (레이트리밋/중복차단)
REDIS_URL=redis://redis:6379/0

# Cloudflare R2 (S3 호환)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=shotpocket

# 분석/임베딩
EMBEDDING_MODEL=bge-m3
VISION_MODE=local

# 운영 API 키 (X-Ops-Key 헤더 검증. Cloudflare Access 뒤 배치 전제)
OPS_API_KEY=change-me-ops-key
